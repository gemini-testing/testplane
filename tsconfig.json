{
    "extends": "./tsconfig.common.json",
    "include": ["src"],
    "exclude": [
        "src/**/__*",
        "src/**/*.test.ts",
        "src/browser/client-scripts",
        "src/bundle/cjs",
        "src/browser-installer/ubuntu-packages/collect-dependencies",
        "src/runner/browser-env/vite/browser-modules"
    ],
    "compilerOptions": {
        "outDir": "build"
    },
    "references": [{
        "path": "./src/runner/browser-env/vite/browser-modules/tsconfig.json"
    }, {
        "path": "./src/browser/client-scripts/screen-shooter/tsconfig.json"
    }, {
        "path": "./src/browser/client-scripts/browser-utils/tsconfig.json"
    }, {
        "path": "./src/browser/isomorphic/tsconfig.json"
    }]
}
